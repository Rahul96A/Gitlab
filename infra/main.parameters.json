{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": {
      "value": "gitlabclone"
    },
    "location": {
      "value": "eastus2"
    },
    "sqlAdminPassword": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/rg-gitlabclone/providers/Microsoft.KeyVault/vaults/kv-gitlabclone"
        },
        "secretName": "SqlAdminPassword"
      }
    },
    "jwtSecret": {
      "reference": {
        "keyVault": {
          "id": "/subscriptions/<SUBSCRIPTION_ID>/resourceGroups/rg-gitlabclone/providers/Microsoft.KeyVault/vaults/kv-gitlabclone"
        },
        "secretName": "JwtSecret"
      }
    },
    "apiImageTag": {
      "value": "latest"
    },
    "frontendImageTag": {
      "value": "latest"
    }
  }
}
